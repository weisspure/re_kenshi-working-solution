enum itemType { STAT_DEFINITION=3000, CLAMP_PROFILE=3001, ADJUST_SKILL_LEVEL=3002, SET_SKILL_LEVEL=3003 }

// DC_STAT_LEVEL_COMPARE_UNMODIFIED: compares two characters' raw base stats.
// DC_STAT_LEVEL_COMPARE_MODIFIED: compares two characters' effective stats.
// These are stricter stat-focused checks than the lightweight Dialogue demo
// conditions: they compare participant-vs-participant whole visible stat levels
// and the runtime fails closed/logs if condition data is malformed.
//   tag  = StatsEnumerated integer -- the same stat is read from both characters.
//   val0 = unused.
//   who  = controls the left-hand side of the comparison.
//          T_ME means: owner OP target (e.g. is the owner stronger than the target?)
//          T_WHOLE_SQUAD means: owner-side OP target; it is not squad-wide.
//          other values mean: target OP owner
//   compareBy = the operator (equals / less than / more than).
//
// Single-character stat threshold checks are intentionally not duplicated here.
// Use BFrizzle's Dialogue conditions for those in pass 1. A future pass may add
// improved threshold checks with real squad-aware behavior under new IDs.
enum DialogConditionEnum { DC_STAT_LEVEL_COMPARE_UNMODIFIED=3004, DC_STAT_LEVEL_COMPARE_MODIFIED=3005 }

// -----------------------------------------------------------------------
// STAT_DEFINITION
//
// Defines a selectable stat for Skill Adjustments and Skill Sets.
//
// Normal FCS users should use the provided Stat Definition records shipped
// with this mod, such as Strength, Athletics, Toughness, etc.
//
// Plugin authors adding new stats:
// Ship your own STAT_DEFINITION records in your .mod alongside your plugin.
// Set "enum value" to your stat's StatsEnumerated integer and publish that
// value so others can build compatibility records without needing your source.
//
// Want compatibility for a plugin that did not ship records?
// Create a STAT_DEFINITION record in your own .mod and set "enum value" to
// the integer that plugin uses for its stat. You do not need the source;
// you only need the published integer value.
//
// Vanilla stat integers are fixed in the Kenshi binary and should not change.
// Incorrect enum values may modify the wrong stat or be rejected by runtime.
// -----------------------------------------------------------------------
[STAT_DEFINITION]
enum value: 0 "Internal stat ID used by runtime. Use the provided Stat Definitions unless adding support for another StatsEnumerated value."
comments: "" "Author-facing notes for FCS users. Ignored by runtime."

// -----------------------------------------------------------------------
// CLAMP_PROFILE
// Reusable clamp policies. Reference from an ADJUST_SKILL_LEVEL or
// SET_SKILL_LEVEL record to enable clamping. Leave the reference empty
// on an action record to disable clamping entirely.
// -----------------------------------------------------------------------
[CLAMP_PROFILE]
clamp min: 0         "Inclusive lower bound."
clamp max: 100       "Inclusive upper bound."
comments: "" multiline "Author-facing notes. Ignored by runtime."

// -----------------------------------------------------------------------
// ADJUST_SKILL_LEVEL
// val0 = amount to add (train actions) or subtract (untrain actions).
// stat  = reference to a STAT_DEFINITION record.
// clamp profile = optional reference to a CLAMP_PROFILE record.
//                 Leave empty for no clamping.
// -----------------------------------------------------------------------
[ADJUST_SKILL_LEVEL]
stat: STAT_DEFINITION (0)        "Which stat to modify. Pick a STAT_DEFINITION record. Val 0 shown here is unused."
clamp profile: CLAMP_PROFILE (0) "Optional clamping policy. Leave empty for no clamping. Val 0 shown here is unused."
comments: "" multiline                     "Author-facing notes. Ignored by runtime."

// -----------------------------------------------------------------------
// SET_SKILL_LEVEL
// val0 = value to assign exactly (train/untrain until actions).
// -----------------------------------------------------------------------
[SET_SKILL_LEVEL]
stat: STAT_DEFINITION (0)        "Which stat to set. Pick a STAT_DEFINITION record. Val 0 shown here is unused."
clamp profile: CLAMP_PROFILE (0) "Optional clamping policy. Leave empty for no clamping. Val 0 shown here is unused."
comments: "" multiline                     "Author-facing notes. Ignored by runtime."

[FCS_LAYOUT]
Characters:               CHARACTER
    Skill Adjustments:    ADJUST_SKILL_LEVEL
        Stat Definitions: STAT_DEFINITION
        Clamp Profiles:   CLAMP_PROFILE
    Skill Sets:           SET_SKILL_LEVEL

[DIALOGUE,DIALOGUE_LINE,WORD_SWAPS]
train skill levels: ADJUST_SKILL_LEVEL (0) "Adds val0 to the FCS speaker dropdown's resolved character, not necessarily the visible UI speaker. Use a positive number. 0 means 0."
untrain skill levels: ADJUST_SKILL_LEVEL (0) "Removes val0 from the FCS speaker dropdown's resolved character, not necessarily the visible UI speaker. Use a positive number. 0 means 0."
train other skill levels: ADJUST_SKILL_LEVEL (0) "Adds val0 to the other main dialogue side: owner->target, otherwise->owner. Interjectors count as otherwise. 0 means 0."
untrain other skill levels: ADJUST_SKILL_LEVEL (0) "Removes val0 from the other main dialogue side: owner->target, otherwise->owner. Interjectors count as otherwise. 0 means 0."
train squad skill levels: ADJUST_SKILL_LEVEL (0) "Adds val0 to each active member of the FCS speaker dropdown's resolved platoon. Use a positive number. 0 means 0."
untrain squad skill levels: ADJUST_SKILL_LEVEL (0) "Removes val0 from each active member of the FCS speaker dropdown's resolved platoon. Use a positive number. 0 means 0."
train other squad skill levels: ADJUST_SKILL_LEVEL (0) "Adds val0 to each active member of the other main dialogue side's resolved platoon. Use a positive number. 0 means 0."
untrain other squad skill levels: ADJUST_SKILL_LEVEL (0) "Removes val0 from each active member of the other main dialogue side's resolved platoon. Use a positive number. 0 means 0."

train skill levels until: SET_SKILL_LEVEL (0) "Sets the FCS speaker dropdown's resolved character to val0 exactly. This may differ from the visible UI speaker. 0 means 0."
untrain skill levels until: SET_SKILL_LEVEL (0) "Sets the FCS speaker dropdown's resolved character to val0 exactly. This may differ from the visible UI speaker. 0 means 0."
train other skill levels until: SET_SKILL_LEVEL (0) "Sets the other dialogue side to val0 exactly. Use when raising them toward a target level. 0 means 0."
untrain other skill levels until: SET_SKILL_LEVEL (0) "Sets the other dialogue side to val0 exactly. Use when lowering them toward a target level. 0 means 0."
train squad skill levels until: SET_SKILL_LEVEL (0) "Sets each active member of the FCS speaker dropdown's resolved platoon to val0 exactly. 0 means 0."
untrain squad skill levels until: SET_SKILL_LEVEL (0) "Sets each active member of the FCS speaker dropdown's resolved platoon to val0 exactly. 0 means 0."
train other squad skill levels until: SET_SKILL_LEVEL (0) "Sets each active member of the other main dialogue side's resolved platoon to val0 exactly. 0 means 0."
untrain other squad skill levels until: SET_SKILL_LEVEL (0) "Sets each active member of the other main dialogue side's resolved platoon to val0 exactly. 0 means 0."
